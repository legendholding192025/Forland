# Copy to your host as environment variables or merge into .env.local for local staging tests.
# Staging uses direct PostgreSQL (no Supabase client). Production keeps Supabase — do not set NEXT_PUBLIC_DATA_BACKEND there.

NEXT_PUBLIC_DATA_BACKEND=postgres

POSTGRES_HOST=your-rds-or-k8s-host.region.elb.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=web_forland
POSTGRES_USER=postgres
# Use your real password in the deployment secret store; avoid committing it to git.
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# Optional: set your staging site URL for SEO metadata
# NEXT_PUBLIC_SITE_URL=https://staging.forland.example

# Email (Resend) — use staging keys if you have them
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# Admin UI password (NEXT_PUBLIC_ is required for client-side check in this app)
# NEXT_PUBLIC_ADMIN_PASSWORD=
